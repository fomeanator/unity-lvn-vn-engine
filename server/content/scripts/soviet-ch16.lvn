  },
  {
   "op": "say",
   "text": "Олеся…",
   "who": "Daniil"
  },
  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Давай я тебе помогу.",
   "who": "Главный герой"
  },
