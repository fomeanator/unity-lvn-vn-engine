  },
  {
   "enter": "fade",
   "id": "Andrey",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Андрей_Обычный.png"
  },
  {
   "op": "say",
   "text": "Почему ты спрашиваешь об этом?",
