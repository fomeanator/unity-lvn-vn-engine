   "op": "label"
  },
  {
   "op": "say",
   "text": "Даже удивительно, что Андрей отпустил нас на такое не совсем законное дело.",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
