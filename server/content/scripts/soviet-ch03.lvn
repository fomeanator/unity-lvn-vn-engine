  },
  {
   "op": "say",
   "text": "О-о-о… Это будет увлекательный рассказ.",
   "who": "Timur"
  },
  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Andrey",
