  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Дикие походы!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Возьмешь меня как-нибудь с собой?",
