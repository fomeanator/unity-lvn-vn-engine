  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Пока Люба косо посматривает на меня, в комнату, постучавшись, влетают парни.",
   "who": "Автор"
  },
  {
   "key": "Wardrobe.Timur",
   "op": "set",
