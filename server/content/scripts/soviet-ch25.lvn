  },
  {
   "op": "say",
   "text": "[onetime]«Щелкунчик».",
   "who": "Игрок"
  },
  {
   "op": "say",
   "text": "До Нового года далековато…",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Кажется, я перепутала…",
   "who": "Главный герой"
  },
  {
   "label": "n16_000000",
