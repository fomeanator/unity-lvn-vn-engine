   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Ну мы же с тобой кубанские казачки – мы можем с мужиками сладить.",
