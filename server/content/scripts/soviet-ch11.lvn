   "id": "Agnia_fairy",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Mother_Fairy",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Mother_Fairy.png"
  },
  {
   "op": "say",
   "text": "Я не боюсь, матушка.",
