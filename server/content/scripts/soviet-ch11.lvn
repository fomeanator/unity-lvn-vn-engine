  {
   "op": "say",
   "text": "Но в голове я постоянно держу, куда собралась после работы.",
   "who": "Автор"
  },
  {
   "id": "Фойе_общаги",
   "op": "bg",
   "sprite_url": "/content/bg/Фойе_общаги.jpg"
  },
  {
   "key": "Music.Miracle",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Прежде чем отправиться туда, куда я собиралась, я решаю заскочить в общежитие.",
   "who": "Автор"
  },
  {
   "else": "n30_000000",
