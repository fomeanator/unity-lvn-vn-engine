   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Андрей_Обычный.png"
  },
  {
   "op": "say",
   "text": "И как вы это докажете?",
   "who": "Andrey"
  },
  {
   "op": "say",
   "text": "Машина ваша, была закрыта.",
   "who": "Andrey"
  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Товарищ дружинник, но это точно не мое!",
   "who": "Psychiatrist"
  },
  {
   "op": "say",
   "text": "Я психиатр! Уважаемый человек!",
   "who": "Psychiatrist"
  },
  {
   "enter": "fade",
   "id": "Andrey",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Андрей_Обычный.png"
  },
  {
   "op": "say",
