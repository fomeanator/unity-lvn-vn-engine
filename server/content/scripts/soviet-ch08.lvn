   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Кратко так кратко!",
   "who": "Timur"
  },
  {
   "op": "say",
   "text": "Я не был примерным пионером.",
   "who": "Timur"
