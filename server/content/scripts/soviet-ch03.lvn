  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Как поступить?",
   "who": "Автор"
  },
  {
   "op": "choice",
   "options": [
