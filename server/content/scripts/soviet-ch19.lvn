  },
  {
   "id": "Черный_фон",
   "op": "bg",
   "sprite_url": "/content/bg/Черный_фон.jpg"
  },
  {
   "op": "say",
   "text": "И проваливаюсь в темноту.",
   "who": "Автор"
  },
  {
   "label": "__end",
   "op": "goto"
  },
  {
   "id": "n58_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Просто хочу покинуть это печальное место.",
   "who": "Игрок"
  },
  {
   "op": "say",
   "text": "...",
   "who": "Главный герой"
  },
  {
   "label": "n59_000000",
