   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я…совершенно не знаю, что ждет меня дальше.",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "И что ждет нас с тобой…",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
