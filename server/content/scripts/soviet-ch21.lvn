   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "В 1995 году.",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
   "op": "say",
   "text": "Сначала нужно создать план.",
   "who": "Daniil"
  },
  {
   "op": "say",
   "text": "Главное, чтобы Мелентьев не раскрыл наши карты слишком рано. Время и информация – наши главные козыри.",
   "who": "Daniil"
  },
