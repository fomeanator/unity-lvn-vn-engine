   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "…",
   "who": "Lyuba"
  },
  {
   "op": "say",
   "text": "Шо же ты нам сразу такое уморительное не показала?",
