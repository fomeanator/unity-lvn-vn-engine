   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Ну вот мы снова и встретились…",
   "who": "Timur"
  },
  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Тимур обводит меня восхищенным взглядом.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
