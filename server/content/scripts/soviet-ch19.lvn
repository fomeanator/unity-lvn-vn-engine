  },
  {
   "op": "say",
   "text": "Даже тошно смотреть на этот щенячий восторг.",
   "who": "Главный герой"
  },
  {
   "id": "n12_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Девушка подлетает к родителям, крепко их обнимая.",
   "who": "Автор"
  },
  {
   "key": "Wardrobe.FreeWardrobe_Access",
   "op": "set",
   "value": false
  },
  {
   "expr": "Wardrobe.mainCh_Clothes",
