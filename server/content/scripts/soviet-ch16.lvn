   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Отламываю ложкой кусочек суфле с бисквитом и протягиваю Любе.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
