   "enter": "fade",
   "id": "Tatyana_Gennadievna",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Tatyana_Gennadievna.jpg"
  },
  {
   "op": "say",
   "text": "И что коровы сами не могут рожать?",
   "who": "Tatyana_Gennadievna"
  },
  {
   "exit": "fade",
   "id": "Tatyana_Gennadievna",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Люба задыхается от возмущения и скрещивает руки на груди.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Шо за рассуждения?",
   "who": "Lyuba"
  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я подхожу к маме Андрея и шепотом спрашиваю ее.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Так кто она?",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Praskovia",
   "op": "actor",
   "position": "right",
