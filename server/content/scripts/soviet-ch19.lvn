  {
   "enter": "fade",
   "id": "Phobos",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Phobos.jpg"
  },
  {
   "op": "say",
   "text": "Будешь сейчас смотреть то, что было дальше?",
