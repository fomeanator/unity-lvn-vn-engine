   "enter": "fade",
   "id": "Laboratory_assistant",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Laboratory_assistant.png"
  },
  {
   "op": "say",
   "text": "После этого я обходила его за километр.",
