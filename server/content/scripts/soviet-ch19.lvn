  },
  {
   "op": "choice",
   "options": [
    {
     "goto": "n57_000000",
     "text": "Вспоминаю продолжение маминой сказки о Морской Деве…"
    },
    {
     "goto": "n58_000000",
     "text": "Просто хочу покинуть это печальное место."
