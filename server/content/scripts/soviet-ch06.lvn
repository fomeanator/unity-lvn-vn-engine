   "value": true
  },
  {
   "id": "n43_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Даня, а тебе еще долго возиться со всем этим?",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
