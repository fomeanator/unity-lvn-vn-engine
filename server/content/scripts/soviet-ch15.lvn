   "sprite_url": "/content/art/Андрей_Обычный.png"
  },
  {
   "op": "say",
   "text": "Можем. Приемная открыта там и в выходные, кабинет председателя в том же здании.",
   "who": "Andrey"
  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
