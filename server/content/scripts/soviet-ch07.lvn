  },
  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Благодаря вам всем.",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Благодаря тебе, Любе, Андрею и Тимуру.",
   "who": "Главный герой"
  },
