   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Men2.jpg"
  },
  {
   "op": "say",
   "text": "Да это ты… ты меня совсем не уважаешь!",
   "who": "Men2"
  },
  {
   "op": "say",
   "text": "К моей жене лез!",
   "who": "Men2"
