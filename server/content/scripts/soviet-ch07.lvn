  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Так без предупреждения, Даня?",
