  },
  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Для меня это все слишком…",
   "who": "Главный герой"
  },
  {
   "op": "choice",
   "options": [
