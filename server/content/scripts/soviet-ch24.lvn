   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Лучше поздно, чем…",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Тимур повышает тон и перебивает меня, заканчивает фразу на свой манер.",
