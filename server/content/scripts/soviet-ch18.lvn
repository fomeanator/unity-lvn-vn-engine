   "sprite_url": "/content/art/Phobos.jpg"
  },
  {
   "op": "say",
   "text": "Тьма, которую я сдерживаю, сейчас вырвется и поглотит тебя.",
   "who": "Phobos"
  },
  {
   "exit": "fade",
   "id": "Phobos",
   "op": "actor",
   "show": false
  },
  {
