  },
  {
   "key": "Music.Native",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Даниил обеспокоенно наблюдает за тем, как его друзья переплывают реку.",
   "who": "Автор"
  },
  {
   "enter": "fade",
