     "goto": "n12_000000",
     "text": "Не буду!"
    }
   ]
  },
  {
   "id": "n11_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Буду!",
   "who": "Игрок"
  },
  {
   "op": "say",
   "text": "Ты, Тимур, в своем репертуаре!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Я буду пить газировку не потому что ты меня на слабо взял!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "А потому что я сама хочу пить!",
   "who": "Главный герой"
  },
  {
   "else": "n14_000000",
   "expr": "Remember.TakeaWallet == true",
