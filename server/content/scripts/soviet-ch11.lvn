  },
  {
   "op": "say",
   "text": "Не спеши, Олеся, скоро сама все увидишь!",
   "who": "Andrey"
  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
