   "sprite_url": "/content/bg/Скала_пасмурно.jpg"
  },
  {
   "key": "Music.Sound_of_storm",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Однажды Владычица Морская поднялась с глубин океана к своей дочери, чтобы убедить ее вернуться домой.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Воды забурлили, и Владычицу на высокой волне вынесло на берег.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Mother_Fairy",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Mother_Fairy.png"
  },
  {
   "op": "say",
