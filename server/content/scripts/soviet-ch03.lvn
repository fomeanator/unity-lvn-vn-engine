  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Как поступить с врачом?",
   "who": "Автор"
  },
  {
   "op": "choice",
   "options": [
