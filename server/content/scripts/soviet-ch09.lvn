   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Очень. Даже захотелось побывать на лугу и наплести венки из цветов.",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
