  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Люба гладит корову по хребту, по голове, по раздутым бокам.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Помыв руки, она приступает к делу.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Что… ты собираешься делать?",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Надо перевернуть теленка.",
