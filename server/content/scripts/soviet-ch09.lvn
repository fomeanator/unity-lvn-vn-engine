   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Ловлю тебя на слове. Хочу увидеть тебя с цветочным венком на голове.",
   "who": "Timur"
  },
  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "А где же вы нашли цветы?",
