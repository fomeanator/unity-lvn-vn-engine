   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "А эта Татьяна Геннадьевна, которая, видно же, ничего не знает о сельской жизни.",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Andrey",
   "op": "actor",
   "position": "right",
