  },
  {
   "op": "say",
   "text": "А как же? Мы же вытащили тебя отсюда!",
   "who": "Lyuba"
  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
