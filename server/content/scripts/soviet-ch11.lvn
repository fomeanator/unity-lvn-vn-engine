  },
  {
   "exit": "fade",
   "id": "Mother_Fairy",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Father_fairy",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Father_fairy.png"
  },
  {
   "op": "say",
   "text": "Я никогда не причиню боль вашей дочери.",
   "who": "Father_fairy"
  },
  {
   "op": "say",
   "text": "Я люблю ее и собираюсь на ней жениться.",
