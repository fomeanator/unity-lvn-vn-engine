  },
  {
   "id": "Фойе_общежития",
   "op": "bg",
   "sprite_url": "/content/bg/Фойе_общежития.jpg"
  },
  {
   "op": "say",
   "text": "Спустившись с лестницы, я подхожу к телефону и беру трубку.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "М… Аня?",
