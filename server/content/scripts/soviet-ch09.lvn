  },
  {
   "op": "say",
   "text": "Все будет хорошо и даже превосходно.",
   "who": "Timur"
  },
  {
   "op": "say",
   "text": "А в твоей прелестной голове слишком много грустных мыслей.",
   "who": "Timur"
  },
  {
   "op": "say",
   "text": "Иногда полезно ни о чем не грузиться и начать уже просто жить.",
   "who": "Timur"
  },
  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Ты прав.",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
   "position": "right",
