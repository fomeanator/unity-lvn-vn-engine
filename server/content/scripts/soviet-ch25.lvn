   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Танцы Зигфрида с Одиллией.",
   "who": "Lyuba"
  },
  {
   "op": "say",
   "text": "Потом Зигфрид поцелует Одиллию, нарушив клятву вечной любви.",
   "who": "Lyuba"
  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
