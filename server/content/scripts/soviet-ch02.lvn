  },
  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "...",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Как отреагировать?",
