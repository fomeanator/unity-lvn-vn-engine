  },
  {
   "id": "n62_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Дима бесшумно вздыхает и пытается не распаляться.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Young_Father",
   "op": "actor",
