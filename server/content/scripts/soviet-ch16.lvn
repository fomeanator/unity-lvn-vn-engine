  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Вскоре девушка приносит кипу женских журналов, и мы с ней погружаемся в изучение советской моды…",
   "who": "Автор"
  },
  {
   "id": "n44_000000",
   "op": "label"
  },
  {
   "else": "n48_000000",
   "expr": "Remember.Exchange_numbers_1_11 == true",
