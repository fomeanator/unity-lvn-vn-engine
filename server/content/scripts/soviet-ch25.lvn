   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Любаша, ты же знаешь, я не поклонница вычурности…",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Lyuba",
