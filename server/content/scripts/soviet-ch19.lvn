   "op": "set"
  },
  {
   "key": "Wardrobe.mainCh_Clothes",
   "op": "set",
   "value": 11
  },
  {
   "key": "Wardrobe.mainCh_Hair",
   "op": "set",
   "value": 11
  },
  {
   "op": "say",
   "text": "Ну все, не злитесь на меня, мама и папа!",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Mother_2",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/E8LAbHj7OPY (1).jpg"
  },
  {
   "op": "say",
   "text": "Ладно, мы сейчас пойдем купим билеты.",
   "who": "Mother_2"
  },
  {
   "exit": "fade",
   "id": "Mother_2",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Father_3",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/dv_qVPrDh3o (1).jpg"
  },
  {
   "op": "say",
   "text": "Ты с нами?",
   "who": "Father_3"
  },
  {
   "exit": "fade",
   "id": "Father_3",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я вас на улице подожду.",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Mother_2",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/E8LAbHj7OPY (1).jpg"
  },
  {
   "op": "say",
   "text": "Только не думай снова сбежать!",
   "who": "Mother_2"
  },
  {
   "exit": "fade",
   "id": "Mother_2",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я и не собиралась!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Честное-пречестное слово!",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Father_3",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/dv_qVPrDh3o (1).jpg"
  },
  {
   "op": "say",
   "text": "Там еще есть забегаловка. Ты голодная? Тебе что-нибудь купить?",
   "who": "Father_3"
  },
  {
   "exit": "fade",
   "id": "Father_3",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Да, купи мне…",
   "who": "Главный герой"
  },
  {
   "op": "choice",
   "options": [
    {
     "goto": "n13_000000",
     "text": "Кимбап!"
    },
    {
     "goto": "n14_000000",
     "text": "Токпокки!"
    },
    {
     "goto": "n15_000000",
     "text": "Пянсе!"
