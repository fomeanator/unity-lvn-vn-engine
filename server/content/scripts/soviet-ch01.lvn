  },
  {
   "enter": "fade",
   "id": "Marina",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Марина_Обычная.png"
  },
  {
   "op": "say",
   "text": "Да-а-а… Какой же все-таки облом, Олеся!",
   "who": "Marina"
  },
  {
