   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Она тянется за косметичкой на столе, роется в ней и затем подает мне коробочку.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Что это?",
