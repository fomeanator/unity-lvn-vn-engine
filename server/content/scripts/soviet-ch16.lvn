   "op": "set"
  },
  {
   "op": "say",
   "text": "Вы хотите поддержать своих родителей!",
   "who": "Выбор пути"
  },
  {
   "op": "say",
   "text": "Пытаются навязать нам, как жить, с кем встречаться… А как же наши чувства?",
   "who": "Главный герой"
  },
  {
   "label": "n51_000000",
   "op": "goto"
  },
  {
   "id": "n46_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "После такого непростого дня чай с медом.",
   "who": "Игрок"
  },
  {
   "enter": "fade",
