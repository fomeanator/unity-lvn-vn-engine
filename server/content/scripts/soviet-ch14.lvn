   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Колхоз без ветеринара? Как интересно, да ведь, Андрей?",
   "who": "Timur"
  },
  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Andrey",
