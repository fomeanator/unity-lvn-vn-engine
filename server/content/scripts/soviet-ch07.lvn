   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Тимур подходит ближе к другу и хлопает его по плечу.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
