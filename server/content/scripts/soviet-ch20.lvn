  },
  {
   "exit": "fade",
   "id": "Seagull",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Но как ты здесь оказалась?",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Эта чайка не может быть настоящей, ведь это всего лишь мой сон.",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Игры разума.",
   "who": "Главный герой"
  },
  {
   "key": "Sound.Bird_scream",
   "op": "set",
   "value": true
  },
  {
   "enter": "fade",
   "id": "Seagull",
