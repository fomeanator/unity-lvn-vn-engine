   "id": "Daniels_bathroom",
   "op": "bg",
   "sprite_url": "/content/bg/Daniels_bathroom.jpg"
  },
  {
   "op": "say",
   "text": "Толкнув незапертую дверь, я оказываюсь прямо перед ошарашенным парнем.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
