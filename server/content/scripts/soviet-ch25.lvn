  {
   "enter": "fade",
   "id": "Svetlana_Ulanova",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Svetlana_Ulanova.png"
  },
  {
   "op": "say",
   "text": "…",
