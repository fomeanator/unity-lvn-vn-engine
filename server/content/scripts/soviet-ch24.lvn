  },
  {
   "op": "say",
   "text": "Путь трудолюбия.",
   "who": "Выбор пути"
  },
  {
   "op": "say",
   "text": "Давай вернемся к друзьям хотя бы на последней электричке.",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Как они без нас работать будут…",
   "who": "Главный герой"
  },
