   "who": "Выбор пути"
  },
  {
   "op": "say",
   "text": "Хотелось бы знать, с кем мы имеем честь говорить.",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Tatyana_Gennadievna",
