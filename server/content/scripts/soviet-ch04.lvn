   "sprite_url": "/content/art/Андрей_Обычный.png"
  },
  {
   "op": "say",
   "text": "Погнали.",
   "who": "Andrey"
  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
