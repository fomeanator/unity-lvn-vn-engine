    }
   ]
  },
  {
   "id": "n102_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "[premium]Уговорить ее.",
   "who": "Игрок"
  },
  {
   "op": "say",
   "text": "Сталина Ильинична, пожалуйста! Очень нужно. Вопрос жизни и смерти!",
