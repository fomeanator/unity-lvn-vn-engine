   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Останься, Андрюша, с нами на субботу!",
   "who": "Lyuba"
  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
