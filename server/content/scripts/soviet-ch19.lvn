   "op": "set"
  },
  {
   "key": "Wardrobe.FreeWardrobe_Access",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Неужели я была такой…",
   "who": "Главный герой"
  },
  {
   "op": "choice",
   "options": [
    {
     "goto": "n10_000000",
     "text": "Наивной?"
