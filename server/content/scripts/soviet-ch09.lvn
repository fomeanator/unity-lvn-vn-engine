   "exit": "fade",
   "id": "Child_Olesya_Cold",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Диким озлобленным зверенышем я жмусь к спинке кровати, закутавшись в одеяло.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Child_Olesya_Cold",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Артс4.jpg"
  },
  {
   "op": "say",
   "text": "Нет!",
