  },
  {
   "exit": "fade",
   "id": "Eleanor",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Наконец она сама подходит ближе. Девушка буквально светится.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Eleanor",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Eleanor.png"
  },
  {
   "op": "say",
   "text": "Это вы! Наша спасительница.",
   "who": "Eleanor"
  },
