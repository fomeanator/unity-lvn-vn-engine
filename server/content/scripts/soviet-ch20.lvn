  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я буду биться, Люба. Буду драться за нас с тобой со всей яростью берсерка.",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Люб, что ты собираешься сейчас делать?",
