  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "А как я отношусь к мести?",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Даниил и Люба никак это не комментируют, а меня вдруг осеняет:",
