  },
  {
   "op": "say",
   "text": "Вы… Здесь?",
   "who": "Главный герой"
  },
  {
   "op": "choice",
   "options": [
    {
     "goto": "n34_000000",
     "text": "Я так вам рада!"
    },
    {
