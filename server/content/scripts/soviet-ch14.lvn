   "sprite_url": "/content/bg/Двор_общаги.jpg"
  },
  {
   "op": "say",
   "text": "Но когда мы выходим на улицу, автобус уже показывает нам свой бампер, обдавая пылью и облаком выхлопных газов.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Andrey",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Андрей_Обычный.png"
  },
  {
   "op": "say",
   "text": "Ну вот, не успели!",
   "who": "Andrey"
  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Недостаточно я торопила Олесю…",
