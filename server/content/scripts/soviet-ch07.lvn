     "text": "Вздохнуть с облегчением."
    }
   ]
  },
  {
   "id": "n35_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Рассердиться на Тимура.",
   "who": "Игрок"
  },
  {
   "expr": "Way.rage + 1",
