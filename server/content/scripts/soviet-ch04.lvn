  {
   "op": "say",
   "text": "Даниил задумывается, затем тянется к своему рюкзаку, доставая оттуда самолетик, и протягивает его мне.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
   "op": "say",
   "text": "Вот, Олеся, я сохранил его.",
   "who": "Daniil"
  },
  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
