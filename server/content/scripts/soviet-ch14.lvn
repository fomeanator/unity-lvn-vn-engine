  },
  {
   "op": "say",
   "text": "Я приму роды! Я принимала у своей Буренки, все знаю, шо да как делать.",
   "who": "Lyuba"
  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я с тобой!",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Да, Олесенька?",
