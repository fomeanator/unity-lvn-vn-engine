  },
  {
   "exit": "fade",
   "id": "Dushman_blood",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Теперь у меня руки не связаны, и теперь я не беспомощный пленник, которого они приковывали цепями, чтобы пытать.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Dushman_blood",
   "op": "actor",
   "position": "right",
