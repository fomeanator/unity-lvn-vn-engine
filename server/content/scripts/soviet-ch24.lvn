   "key": "Music.Adventure",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Люба призывает Андрея встать, чтобы изобразить, как они приехали в Кульпино.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
