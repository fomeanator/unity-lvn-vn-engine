   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я принимаю зажигалку и открываю окно.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Поджигаю самолетик, ветер сдувает языки пламени...",
