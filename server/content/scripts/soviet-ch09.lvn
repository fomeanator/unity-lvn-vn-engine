   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
   "op": "say",
   "text": "Послушайте, земляк. Радиант Пильмана — это совсем простая штука.",
