   "id": "Alina",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Секретарша убегает, а я пока пытаюсь отойти от этой странной сцены.",
   "who": "Автор"
  },
  {
   "else": "n52_000000",
