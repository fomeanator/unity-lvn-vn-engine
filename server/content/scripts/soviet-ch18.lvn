  },
  {
   "exit": "fade",
   "id": "Den",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Земля круглая. Так что как знать?",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Олеся убегает, пока парень провожает ее взглядом.",
