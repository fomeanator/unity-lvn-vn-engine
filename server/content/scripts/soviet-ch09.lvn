  },
  {
   "op": "say",
   "text": "…",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
   "op": "say",
   "text": "Да когда уже приедет врач?!",
