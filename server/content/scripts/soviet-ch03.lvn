  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Та-а-ак… Надо быстро открыть машину и подбросить туда…",
