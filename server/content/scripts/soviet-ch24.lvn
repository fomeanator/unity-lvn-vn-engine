   "enter": "fade",
   "id": "Timur",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Я… Просто смотрю. Мы действительно еще не готовы.",
   "who": "Timur"
  },
  {
   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Платья и правда красивые.",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Но…",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Что сказать?",
   "who": "Главный герой"
  },
  {
   "op": "choice",
   "options": [
