  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Я… Кх-кх-кх…",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Девушка закашливается, затем снова тянется за стаканом, чтобы запить.",
