  },
  {
   "op": "say",
   "text": "Скри-и-и-и!",
   "who": "Seagull"
  },
  {
   "exit": "fade",
   "id": "Seagull",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Она подходит еще ближе и тянет ко мне голову.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Но для чего ты здесь?",
