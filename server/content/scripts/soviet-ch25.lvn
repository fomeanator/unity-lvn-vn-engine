   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Люба о чем-то думает, печально посматривая в окно.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Любаш, ты чего?",
   "who": "Главный герой"
  },
