   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "А теперь я расскажу Олесе!",
   "who": "Timur"
  },
  {
   "op": "say",
   "text": "Ты же не знаешь точно, Люб, что там происходило.",
