   "op": "label"
  },
  {
   "op": "say",
   "text": "Не отвлекать его от работы.",
   "who": "Игрок"
  },
  {
   "op": "say",
   "text": "Не стоит отвлекать Даниила, он же так занят…",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Не хочу быть навязчивой .",
   "who": "Главный герой"
  },
