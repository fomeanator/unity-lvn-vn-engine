   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
   "op": "say",
   "text": "Полагаю… Это смело, но… он предсказал землетрясение?",
   "who": "Daniil"
  },
  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Вы думаете, все крутится вокруг нас?",
