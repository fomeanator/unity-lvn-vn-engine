  },
  {
   "exit": "fade",
   "id": "Svetlana_Ulanova",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Балерина снова не справляется с эмоциями и заливается горькими слезами.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Svetlana_Ulanova",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Svetlana_Ulanova.png"
  },
  {
   "op": "say",
   "text": "…",
