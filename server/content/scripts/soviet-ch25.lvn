  },
  {
   "expr": "Way.calmness + 1",
   "key": "Way.calmness",
   "op": "set"
  },
  {
   "op": "say",
   "text": "+ сдержанность .",
   "who": "Выбор пути"
  },
  {
   "op": "say",
   "text": "То, что будет дальше, разобьет мне сердце…",
   "who": "Главный герой"
  },
  {
   "label": "n106_000000",
   "op": "goto"
  },
