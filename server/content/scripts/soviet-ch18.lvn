  {
   "exit": "fade",
   "id": "Phobos",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Прежде чем я успеваю навредить себе, Фобос вырастает из воздуха передо мной, подхватывает меня и уносит из воспоминания.",
   "who": "Автор"
  },
