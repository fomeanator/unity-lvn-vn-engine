  },
  {
   "key": "Wardrobe.mainCh_Hair",
   "op": "set",
   "value": 182
  },
  {
   "op": "say",
   "text": "Отлично!",
   "who": "Главный герой"
  },
  {
   "id": "n44_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Ты довольна своим внешним видом?",
   "who": "Автор"
  },
  {
   "op": "choice",
   "options": [
    {
     "goto": "n45_000000",
     "text": "Да."
    },
    {
