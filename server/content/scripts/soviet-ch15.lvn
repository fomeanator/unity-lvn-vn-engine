   "sprite_url": "/content/art/Андрей_Обычный.png"
  },
  {
   "op": "say",
   "text": "Идем-идем!",
   "who": "Andrey"
  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "id": "Entrance_collectivefarm",
