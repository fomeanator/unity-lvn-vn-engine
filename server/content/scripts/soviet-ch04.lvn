  },
  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Да какая скука? Уж мы-то ей заскучать не дадим!",
