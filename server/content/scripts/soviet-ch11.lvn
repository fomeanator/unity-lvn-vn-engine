   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
   "op": "say",
   "text": "Присаживайся, Олеся.",
