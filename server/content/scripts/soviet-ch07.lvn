  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Тимур машет нам руками в сторону общежития:",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
