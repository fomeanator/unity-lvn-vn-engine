  },
  {
   "op": "say",
   "text": "?",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Джон!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Опять он!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Что Джон забыл в Большом театре?",
   "who": "Главный герой"
  },
  {
   "op": "choice",
   "options": [
    {
