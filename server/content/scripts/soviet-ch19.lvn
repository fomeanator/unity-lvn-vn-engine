  {
   "enter": "fade",
   "id": "Phobos",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Phobos.jpg"
  },
  {
   "op": "say",
   "text": "Олеся, ты… только не плачь…",
