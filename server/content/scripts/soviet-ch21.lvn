   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Конечно заварю, тебе же столько всего из Кульпино передали!",
   "who": "Lyuba"
  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "id": "Кухня_общаги",
