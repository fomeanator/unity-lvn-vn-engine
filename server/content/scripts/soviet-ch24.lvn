   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Ой, Данечка, прости, шо мы так не подумав…",
   "who": "Lyuba"
  },
  {
   "exit": "fade",
   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
