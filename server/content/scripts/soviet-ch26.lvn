  },
  {
   "enter": "fade",
   "id": "Young_Father",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Young_Father.png"
  },
  {
   "op": "say",
   "text": "Это из-за сегодняшнего? Что она снова напридумывала?",
