  },
  {
   "id": "Скала_пасмурно",
   "op": "bg",
   "sprite_url": "/content/bg/Скала_пасмурно.jpg"
  },
  {
   "key": "Music.Sound_of_storm",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Я снова здесь? Но почему?",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Phobos",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Phobos.jpg"
  },
  {
   "op": "say",
   "text": "Просто потому что ты уснула.",
   "who": "Phobos"
  },
  {
   "exit": "fade",
   "id": "Phobos",
   "op": "actor",
   "show": false
