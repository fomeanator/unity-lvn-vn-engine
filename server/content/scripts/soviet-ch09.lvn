  },
  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "И мандарины – жуткий дефицит. Достать их очень непросто.",
