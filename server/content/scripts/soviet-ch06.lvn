   "op": "say",
   "text": "Вот же ж… подхалимка!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Что сделать?",
   "who": "Автор"
  },
  {
   "op": "choice",
   "options": [
    {
