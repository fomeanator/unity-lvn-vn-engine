  },
  {
   "key": "Music.Sound_of_storm",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Отпусти меня! Я должна туда вернуться!",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Phobos",
   "op": "actor",
   "position": "right",
