  {
   "exit": "fade",
   "id": "Phobos",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Да…",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Phobos",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Phobos.jpg"
  },
  {
   "op": "say",
   "text": "Так задай эти вопросы.",
