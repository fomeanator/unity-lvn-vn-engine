  },
  {
   "exit": "fade",
   "id": "Andrey",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Андрей…",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Я подхожу к нему ближе и крепко обнимаю его.",
   "who": "Автор"
  },
  {
   "op": "say",
   "text": "Когда же они прекратятся…",
   "who": "Главный герой"
  },
  {
   "enter": "fade",
   "id": "Andrey",
   "op": "actor",
   "position": "right",
