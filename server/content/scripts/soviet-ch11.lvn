  },
  {
   "enter": "fade",
   "id": "Lyuba",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Люба_Обычная.png"
  },
  {
   "op": "say",
   "text": "Ну шо за бедовые хлопцы!",
   "who": "Lyuba"
  },
  {
   "else": "n60_000000",
