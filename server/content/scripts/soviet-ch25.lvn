   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Любаша, выглядишь прекрасно!",
   "who": "Timur"
  },
  {
   "key": "Wardrobe.Andrey",
   "op": "set",
   "value": 1
  },
  {
