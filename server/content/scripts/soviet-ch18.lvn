  },
  {
   "op": "choice",
   "options": [
    {
     "goto": "n37_000000",
     "text": "Не менять."
    },
    {
     "goto": "n38_000000",
     "text": "Морячка."
    },
    {
     "goto": "n39_000000",
     "text": "Хозяйка Медной горы."
    }
