  },
  {
   "key": "Music.Miracle",
   "op": "set",
   "value": true
  },
  {
   "op": "say",
   "text": "Дойдя до общежития и до кухни, Тимур падает на стул.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Timur",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Ну и денек, ноги отваливаются!",
