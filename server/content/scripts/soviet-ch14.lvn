   "text": "+ сдержанность",
   "who": "Выбор пути"
  },
  {
   "op": "say",
   "text": "Вечно вы из-за меня попадаете в неприятности…",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Если бы не я…",
   "who": "Главный герой"
  },
  {
   "id": "n9_000000",
   "op": "label"
  },
  {
   "enter": "fade",
