   "exit": "fade",
   "id": "Timur",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "О чем он говорит?",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Но Андрей молча пихает друга локтем в бок, и Тимур замолкает.",
   "who": "Автор"
  },
  {
   "enter": "fade",
   "id": "Daniil",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Даниил_Обычный.png"
  },
  {
   "op": "say",
   "text": "Андрей прав, Олеся. Оставь это позади.",
