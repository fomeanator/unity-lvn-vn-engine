   "enter": "fade",
   "id": "Timur",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Тимур_Обычный.png"
  },
  {
   "op": "say",
   "text": "Вместе с кучей других адресов.",
