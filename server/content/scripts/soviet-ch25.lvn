   "who": "Главный герой"
  },
  {
   "label": "n106_000000",
   "op": "goto"
  },
  {
   "id": "n105_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "Как грустно наблюдать за всем этим…",
