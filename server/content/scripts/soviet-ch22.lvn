  {
   "exit": "fade",
   "id": "Daniil",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Даниил широко раскрывает глаза и вдыхает побольше воздуха, но мгновенно передумывает и отворачивается.",
   "who": "Автор"
