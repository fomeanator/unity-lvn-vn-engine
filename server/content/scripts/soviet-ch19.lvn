   "show": true,
   "sprite_url": "/content/art/Phobos.jpg"
  },
  {
   "op": "say",
   "text": "Олеся, тебе стало хоть немного легче?",
   "who": "Phobos"
  },
  {
   "exit": "fade",
   "id": "Phobos",
   "op": "actor",
   "show": false
