   "id": "Little_Olesya_summer",
   "op": "actor",
   "position": "right",
   "show": true,
   "sprite_url": "/content/art/Little_Olesya_summer.png"
  },
  {
   "op": "say",
   "text": "Оно же будет падать с моей руки, мама!",
