  },
  {
   "expr": "Way.USSR + 1",
   "key": "Way.USSR",
   "op": "set"
  },
  {
   "op": "say",
   "text": "Мне так комфортно, будто родилась и выросла здесь.",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Уж тем более никогда не смогу оставить вас и сбежать обратно.",
   "who": "Главный герой"
  },
  {
   "label": "n70_000000",
   "op": "goto"
  },
  {
   "id": "n62_000000",
   "op": "label"
  },
  {
   "op": "say",
   "text": "А я помогу!",
   "who": "Игрок"
