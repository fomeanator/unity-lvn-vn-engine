   "id": "Lyuba",
   "op": "actor",
   "show": false
  },
  {
   "op": "say",
   "text": "Не паникуй, Любаша!",
   "who": "Главный герой"
  },
  {
   "op": "say",
   "text": "Все с ними будет хорошо!",
   "who": "Главный герой"
